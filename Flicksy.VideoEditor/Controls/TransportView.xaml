<UserControl x:Class="Flicksy.VideoEditor.Controls.TransportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#161616">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TransportBorderBrush" Color="#3DFFFFFF" />
        <SolidColorBrush x:Key="TransportTextBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TimecodeTextBrush" Color="#BDBDBD" />

        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Foreground" Value="{StaticResource TransportTextBrush}" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#222222" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimecodeStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TimecodeTextBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource TransportBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Style="{StaticResource TimecodeStyle}"
                       HorizontalAlignment="Left"
                       Text="{Binding CurrentTimecode}" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource TransportButtonStyle}"
                        Content="Prev"
                        Command="{Binding PrevFrameCommand}" />
                <Button Style="{StaticResource TransportButtonStyle}"
                        MinWidth="72"
                        Content="{Binding PlayPauseLabel}"
                        Command="{Binding PlayPauseCommand}" />
                <Button Style="{StaticResource TransportButtonStyle}"
                        Content="Next"
                        Command="{Binding NextFrameCommand}" />
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Style="{StaticResource TimecodeStyle}"
                       HorizontalAlignment="Right"
                       Text="{Binding TotalTimecode}" />
        </Grid>
    </Border>
</UserControl>
