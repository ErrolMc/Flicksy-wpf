<UserControl x:Class="Flicksy.VideoEditor.Controls.Timeline.TrackHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1B1B1B"
             Width="120"
             Height="56">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderBorderBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="HeaderMutedBrush" Color="#888888" />

        <Style x:Key="TrackToggleStyle" TargetType="ToggleButton" xmlns:tb="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource HeaderMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="400" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#262626" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#3A3A3A" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#55FFFFFF" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource HeaderBorderBrush}"
            BorderThickness="0,0,1,1"
            Padding="8,4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       Foreground="{StaticResource HeaderTextBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- Mute/Lock/Disable stubs. No bound state yet — pure visual toggles until
                 per-track flags + the compositor land (see issue #10 comment thread for
                 the design discussion on Track.{Muted,Locked,Disabled}). -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="0,4,0,0">
                <ToggleButton Style="{StaticResource TrackToggleStyle}"
                              Content="M"
                              ToolTip="Mute (stub)" />
                <ToggleButton Style="{StaticResource TrackToggleStyle}"
                              Content="L"
                              ToolTip="Lock (stub)" />
                <ToggleButton Style="{StaticResource TrackToggleStyle}"
                              Content="D"
                              ToolTip="Disable / hide track (stub)" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
