<UserControl x:Class="Flicksy.VideoEditor.Controls.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:timeline="clr-namespace:Flicksy.VideoEditor.Controls.Timeline"
             Background="#161616">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TimelineRulerHeaderBg" Color="#1F1F1F" />
        <SolidColorBrush x:Key="TimelineRulerHeaderBorder" Color="#333333" />
    </UserControl.Resources>

    <!-- Pinned-headers layout: the header column lives in its own ScrollViewer outside
         the main horizontal scroll, so it stays put when the timeline pans right.
         Three ScrollViewers in total:
           - RulerScroller (row 0, col 1)  : H-slaved to MainScroller, no scrollbars shown
           - HeadersScroller (row 1, col 0): V-slaved to MainScroller, no scrollbars shown
           - MainScroller (row 1, col 1)   : the actual H+V scrolling for lanes
         Slave offsets are pushed by MainScroller's ScrollChanged. The slave scrollers
         carry small fixed margins to reserve gutter space matching MainScroller's H/V
         scrollbars so their content stays aligned with the lanes when scrollbars show.
         Wheel + click handlers attach to the outer Border so they fire anywhere on the
         timeline, regardless of which sub-scroller the cursor is over. -->
    <Border x:Name="RootBorder"
            Background="#161616"
            PreviewMouseWheel="OnRootPreviewMouseWheel"
            PreviewMouseLeftButtonDown="OnRootPreviewMouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- (0,0) Corner spacer above the headers column. -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="{StaticResource TimelineRulerHeaderBg}"
                    BorderBrush="{StaticResource TimelineRulerHeaderBorder}"
                    BorderThickness="0,0,1,1" />

            <!-- (0,1) Ruler. Right margin 12 reserves the gutter where MainScroller's
                 vertical scrollbar lives so ruler content lines up with lane content. -->
            <ScrollViewer x:Name="RulerScroller"
                          Grid.Row="0" Grid.Column="1"
                          Margin="0,0,12,0"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Focusable="False">
                <timeline:TimeRulerView />
            </ScrollViewer>

            <!-- (1,0) Pinned headers. Bottom margin 12 reserves the gutter where
                 MainScroller's horizontal scrollbar lives. -->
            <ScrollViewer x:Name="HeadersScroller"
                          Grid.Row="1" Grid.Column="0"
                          Margin="0,0,0,12"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          Focusable="False">
                <ItemsControl ItemsSource="{Binding Project.Tracks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <timeline:TrackHeaderView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- (1,1) The scrollable lanes + playhead overlay. -->
            <ScrollViewer x:Name="MainScroller"
                          Grid.Row="1" Grid.Column="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="OnMainScrollerScrollChanged"
                          Focusable="False">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Project.Tracks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <timeline:ClipsLaneView Track="{Binding}"
                                                        Timeline="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}">
                                    <timeline:ClipsLaneView.Style>
                                        <Style TargetType="{x:Type timeline:ClipsLaneView}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Disabled}" Value="True">
                                                    <Setter Property="Opacity" Value="0.35" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </timeline:ClipsLaneView.Style>
                                </timeline:ClipsLaneView>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <timeline:PlayheadView IsHitTestVisible="False" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
