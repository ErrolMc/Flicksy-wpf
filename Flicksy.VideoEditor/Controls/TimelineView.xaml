<UserControl x:Class="Flicksy.VideoEditor.Controls.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Stub. Real timeline content (tracks, clips, ruler) lands in #7 — until then this
         renders a centered placeholder label. The shell-side MouseLeftButtonUp handler on
         this control toggles a synthetic SelectedClip so the right rail can be exercised
         before real clip selection lands; that scaffold goes away with #7. -->
    <Border Background="#161616"
            Cursor="Hand">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Timeline"
                       Foreground="#5A5A5A"
                       FontSize="14"
                       HorizontalAlignment="Center" />
            <TextBlock Text="(dev: click to toggle clip selection)"
                       Foreground="#3A3A3A"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</UserControl>
