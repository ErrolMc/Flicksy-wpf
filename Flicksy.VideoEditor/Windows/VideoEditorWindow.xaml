<Window x:Class="Flicksy.VideoEditor.Windows.VideoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Flicksy.VideoEditor.Converters"
        xmlns:vm="clr-namespace:Flicksy.VideoEditor.ViewModels"
        xmlns:rail="clr-namespace:Flicksy.VideoEditor.Controls.Rail"
        xmlns:panels="clr-namespace:Flicksy.VideoEditor.Controls.Panels"
        xmlns:inspectors="clr-namespace:Flicksy.VideoEditor.Controls.Inspectors"
        Title="Flicksy Video Editor"
        Height="720"
        Width="1200"
        MinHeight="480"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding UndoCommand}" />
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding RedoCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:EnumToVisibilityConverter x:Key="EnumToVis" />

        <SolidColorBrush x:Key="ChromeBackgroundBrush" Color="#202020" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#3DFFFFFF" />
        <SolidColorBrush x:Key="RailBackgroundBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#181818" />
        <SolidColorBrush x:Key="CenterBackgroundBrush" Color="#111111" />
        <SolidColorBrush x:Key="SplitterBrush" Color="#2A2A2A" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#222222" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="BorderBrush" Value="#0078D4" />
        </Style>

        <Style x:Key="ProjectNameBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3DFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBackgroundBrush}"
                BorderBrush="{StaticResource ChromeBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Style="{StaticResource ProjectNameBoxStyle}"
                             Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="Undo"
                            Margin="0,0,8,0"
                            Command="{Binding UndoCommand}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="Redo"
                            Command="{Binding RedoCommand}" />
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryToolbarButtonStyle}"
                        Content="Export"
                        Command="{Binding ExportCommand}" />
            </Grid>
        </Border>

        <!-- Main 5-column body. Panel column widths are managed from code-behind
             so GridSplitter drags can update them without clobbering a binding,
             and toggling IsLeftPanelOpen / IsRightPanelOpen collapses to 0 while
             remembering the user's last drag-resized width. -->
        <Grid x:Name="BodyGrid"
              Grid.Row="1"
              Background="{StaticResource CenterBackgroundBrush}"
              SizeChanged="OnBodyGridSizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition x:Name="LeftPanelColumn" Width="280" MinWidth="0" />
                <ColumnDefinition x:Name="CenterColumn" Width="*" MinWidth="320" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="280" MinWidth="0" />
                <ColumnDefinition x:Name="RightRailColumn" Width="44" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <!-- Left rail -->
            <Border Grid.Column="0"
                    Background="{StaticResource RailBackgroundBrush}"
                    BorderBrush="{StaticResource ChromeBorderBrush}"
                    BorderThickness="0,0,1,0">
                <rail:RailView ItemsSource="{Binding LeftRailItems}"
                               SelectedTag="{Binding CurrentLeftTab, Mode=TwoWay}"
                               IsPanelOpen="{Binding IsLeftPanelOpen, Mode=TwoWay}" />
            </Border>

            <!-- Left panel content -->
            <Grid Grid.Column="1"
                  Background="{StaticResource PanelBackgroundBrush}"
                  Visibility="{Binding IsLeftPanelOpen, Converter={StaticResource BoolToVis}}">
                <panels:MediaPanel       Visibility="{Binding CurrentLeftTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:LeftRailTab.Media}}" />
                <panels:TextPanel        Visibility="{Binding CurrentLeftTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:LeftRailTab.Text}}" />
                <panels:ShapesPanel      Visibility="{Binding CurrentLeftTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:LeftRailTab.Shapes}}" />
                <panels:PenPanel         Visibility="{Binding CurrentLeftTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:LeftRailTab.Pen}}" />
                <panels:TransitionsPanel Visibility="{Binding CurrentLeftTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:LeftRailTab.Transitions}}" />
            </Grid>

            <!-- Left splitter — sibling of the panel grid, sits on its right edge.
                 BasedOnAlignment + HorizontalAlignment=Right resizes the splitter's
                 own column (1, the panel) and the next (2, the center). -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          Width="4"
                          Background="{StaticResource SplitterBrush}"
                          ShowsPreview="False"
                          ResizeDirection="Columns"
                          DragCompleted="OnLeftSplitterDragCompleted"
                          Visibility="{Binding IsLeftPanelOpen, Converter={StaticResource BoolToVis}}" />

            <!-- Center column: Preview / Transport / Timeline placeholders -->
            <Grid Grid.Column="2" Background="{StaticResource CenterBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" MinHeight="160" />
                </Grid.RowDefinitions>

                <!-- Preview placeholder (filled in #6) -->
                <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="{StaticResource ChromeBorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Preview"
                               Foreground="#5A5A5A"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Splitter between Preview and Timeline rows -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="{StaticResource SplitterBrush}"
                              ShowsPreview="False" />

                <!-- Timeline placeholder (filled in #7). Click toggles a synthetic
                     SelectedClip so the right rail can be exercised before real
                     clip selection lands. Scaffold removed when #7 ships. -->
                <Border Grid.Row="2"
                        Background="#161616"
                        BorderBrush="{StaticResource ChromeBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnTimelinePlaceholderClick">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Timeline"
                                   Foreground="#5A5A5A"
                                   FontSize="14"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="(dev: click to toggle clip selection)"
                                   Foreground="#3A3A3A"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right panel content — fixed width (no splitter; inspector widgets
                 are designed against a stable column). -->
            <Grid Grid.Column="3"
                  Background="{StaticResource PanelBackgroundBrush}"
                  Visibility="{Binding IsRightPanelOpen, Converter={StaticResource BoolToVis}}">
                <inspectors:SpeedInspector        Visibility="{Binding CurrentRightTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:RightRailTab.Speed}}" />
                <inspectors:AudioInspector        Visibility="{Binding CurrentRightTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:RightRailTab.Audio}}" />
                <inspectors:AdjustColorsInspector Visibility="{Binding CurrentRightTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:RightRailTab.AdjustColors}}" />
                <inspectors:FiltersInspector      Visibility="{Binding CurrentRightTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:RightRailTab.Filters}}" />
                <inspectors:FadeInspector         Visibility="{Binding CurrentRightTab, Converter={StaticResource EnumToVis}, ConverterParameter={x:Static vm:RightRailTab.Fade}}" />
            </Grid>

            <!-- Visual-only divider matching the left splitter's look. Sits on the
                 right panel's left edge but is not interactive — the right panel is
                 a fixed width, so dragging isn't supported. -->
            <Border Grid.Column="3"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Width="4"
                    Background="{StaticResource SplitterBrush}"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsRightPanelOpen, Converter={StaticResource BoolToVis}}" />

            <!-- Right rail -->
            <Border Grid.Column="4"
                    Background="{StaticResource RailBackgroundBrush}"
                    BorderBrush="{StaticResource ChromeBorderBrush}"
                    BorderThickness="1,0,0,0">
                <rail:RailView ItemsSource="{Binding RightRailItems}"
                               SelectedTag="{Binding CurrentRightTab, Mode=TwoWay}"
                               IsPanelOpen="{Binding IsRightPanelOpen, Mode=TwoWay}" />
            </Border>
        </Grid>
    </Grid>
</Window>
