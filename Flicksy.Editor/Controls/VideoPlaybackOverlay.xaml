<UserControl x:Class="Flicksy.Editor.Controls.VideoPlaybackOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="56">
    <Border Background="#88000000"
            CornerRadius="8"
            Margin="12"
            Padding="10">
        <Grid VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="PlayPauseButton"
                    Width="84"
                    Height="30"
                    Click="OnPlayPauseClick"
                    Content="Play" />

            <Slider x:Name="TimelineSlider"
                    Grid.Column="2"
                    Minimum="0"
                    Maximum="0"
                    Value="0"
                    IsMoveToPointEnabled="True"
                    VerticalAlignment="Center"
                    PreviewMouseLeftButtonDown="OnSliderMouseDown"
                    PreviewMouseLeftButtonUp="OnSliderMouseUp"
                    ValueChanged="OnSliderValueChanged" />

            <TextBlock x:Name="TimeText"
                       Grid.Column="4"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontFamily="Consolas"
                       Text="00:00 / 00:00" />
        </Grid>
    </Border>
</UserControl>
