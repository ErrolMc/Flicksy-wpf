<UserControl x:Class="Flicksy.Editor.Controls.SelectionOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flicksy.Editor.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SelectionOverlayViewModel, IsDesignTimeCreatable=False}"
             IsHitTestVisible="False"
             Background="Transparent">
    <Canvas x:Name="OverlayCanvas">
        <Rectangle x:Name="SelectionBox"
                   Stroke="#B0B0B0"
                   StrokeThickness="1"
                   Fill="Transparent"
                   SnapsToDevicePixels="False" />
        <Ellipse x:Name="HandleTopLeft"
                 Width="8" Height="8"
                 Fill="White"
                 Stroke="#808080"
                 StrokeThickness="1" />
        <Ellipse x:Name="HandleTopRight"
                 Width="8" Height="8"
                 Fill="White"
                 Stroke="#808080"
                 StrokeThickness="1" />
        <Ellipse x:Name="HandleBottomLeft"
                 Width="8" Height="8"
                 Fill="White"
                 Stroke="#808080"
                 StrokeThickness="1" />
        <Ellipse x:Name="HandleBottomRight"
                 Width="8" Height="8"
                 Fill="White"
                 Stroke="#808080"
                 StrokeThickness="1" />
        <Border x:Name="RotateHandle"
                Width="26" Height="26"
                CornerRadius="13"
                Background="#202020"
                BorderBrush="#55FFFFFF"
                BorderThickness="1">
            <Image x:Name="RotateHandleIcon"
                   Width="14" Height="14"
                   Stretch="Uniform" />
        </Border>
    </Canvas>
</UserControl>
