<Window x:Class="Flicksy.Editor.PostSnipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Flicksy.Editor.Controls"
        Title="Post Snip"
        Height="600"
        Width="1000"
        MinHeight="420"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="#111111">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#1F1F1F"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Post Snip"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SaveButton"
                            Width="88"
                            Height="32"
                            Margin="0,0,8,0"
                            Content="Save"
                            Click="OnSaveClick" />
                    <Button x:Name="CancelButton"
                            Width="88"
                            Height="32"
                            Content="Cancel"
                            Click="OnCancelClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="#111111">
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   Visibility="Collapsed" />

            <MediaElement x:Name="PreviewVideo"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          ScrubbingEnabled="True"
                          Stretch="Uniform"
                          Visibility="Collapsed" />

            <controls:VideoPlaybackOverlay x:Name="PlaybackOverlay"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Bottom"
                                           Panel.ZIndex="10" />

            <TextBlock x:Name="EmptyStateText"
                       Text="No media selected"
                       Foreground="#BDBDBD"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>
    </DockPanel>
</Window>
