<Window x:Class="Flicksy.Editor.PostSnipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Flicksy.Editor.Controls"
        Title="Flicksy"
        Height="600"
        Width="1000"
        MinHeight="420"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="#121212">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="ChromeBackgroundBrush" Color="#202020" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#3DFFFFFF" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#1683D8" />
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#006CBE" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#333333" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#3F3F3F" />
        <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#55FFFFFF" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryButtonPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ChromeBackgroundBrush}"
                BorderBrush="{StaticResource ChromeBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="NewButton"
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                        Content="New"
                        Command="{Binding NewCommand}" />

                <controls:ImageEditToolsView x:Name="ImageEditToolsPanel"
                                             Grid.Column="1"
                                             Width="250"
                                             VerticalAlignment="Center"
                                             DataContext="{Binding ImageEditTools}"
                                             Visibility="{Binding DataContext.IsImage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="SaveButton"
                            Style="{StaticResource PrimaryToolbarButtonStyle}"
                            Margin="0,0,8,0"
                            Content="Save"
                            Command="{Binding SaveCommand}" />
                    <Button x:Name="CancelButton"
                            Style="{StaticResource SecondaryToolbarButtonStyle}"
                            Content="Cancel"
                            Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="#111111">
            <Grid x:Name="ImageViewport"
                  ClipToBounds="True"
                  Background="Transparent"
                  Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"
                  MouseWheel="OnImageViewportMouseWheel"
                  PreviewMouseDown="OnImageViewportPreviewMouseDown"
                  MouseMove="OnImageViewportMouseMove"
                  PreviewMouseUp="OnImageViewportPreviewMouseUp"
                  SizeChanged="OnImageViewportSizeChanged">
                <!--
                    Canvas (not Grid) so the image renders at its natural pixel size and
                    is not clipped by the viewport's layout slot. The pan/zoom RenderTransform
                    is responsible for fitting it visually.
                -->
                <Canvas x:Name="ImageContent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Width="{Binding ElementName=EditedImage, Path=ActualWidth}"
                        Height="{Binding ElementName=EditedImage, Path=ActualHeight}"
                        RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0" />
                        </TransformGroup>
                    </Canvas.RenderTransform>
                    <Image x:Name="EditedImage"
                           Stretch="None"
                           Source="{Binding ImageSource}"
                           SizeChanged="OnEditedImageSizeChanged" />
                    <controls:DrawingView DataContext="{Binding Drawing}"
                                          Width="{Binding ElementName=EditedImage, Path=ActualWidth}"
                                          Height="{Binding ElementName=EditedImage, Path=ActualHeight}"
                                          StrokeBrush="{Binding DataContext.ImageEditTools.PenSettings.SelectedColor.Brush, RelativeSource={RelativeSource AncestorType=Window}}"
                                          StrokeThickness="{Binding DataContext.ImageEditTools.PenSettings.Size, RelativeSource={RelativeSource AncestorType=Window}}"
                                          IsErasing="{Binding DataContext.ImageEditTools.IsEraseActive, RelativeSource={RelativeSource AncestorType=Window}}"
                                          IsSelectActive="{Binding DataContext.ImageEditTools.IsSelectActive, RelativeSource={RelativeSource AncestorType=Window}}"
                                          ContentScale="{Binding ElementName=ImageScaleTransform, Path=ScaleX}"
                                          IsHitTestVisible="{Binding DataContext.ImageEditTools.IsImageToolActive, RelativeSource={RelativeSource AncestorType=Window}}" />
                </Canvas>
                <controls:SelectionOverlayView DataContext="{Binding SelectionOverlay}"
                                               ContentToViewport="{Binding ElementName=ImageContent, Path=RenderTransform}"
                                               Panel.ZIndex="5" />
            </Grid>

            <controls:VideoSurface Player="{Binding Player}"
                                   Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}" />

            <controls:VideoPlaybackOverlay Player="{Binding Player}"
                                           Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}"
                                           VerticalAlignment="Bottom"
                                           Panel.ZIndex="10" />

            <TextBlock Text="No media selected"
                       Foreground="#BDBDBD"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </DockPanel>
</Window>
