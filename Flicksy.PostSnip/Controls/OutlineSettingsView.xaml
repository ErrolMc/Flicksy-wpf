<UserControl x:Class="Flicksy.PostSnip.Controls.OutlineSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SliderTrackBrush" Color="#3FFFFFFF" />
        <SolidColorBrush x:Key="SliderProgressBrush" Color="#C2185B" />
        <SolidColorBrush x:Key="SliderThumbBrush" Color="#C2185B" />

        <Style x:Key="ColorSwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ColorSwatch" Fill="{Binding Brush}" />
                            <Image x:Name="NoneImage"
                                   Source="{Binding DataContext.CrossCircle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Stretch="Uniform"
                                   Visibility="Collapsed" />
                            <Ellipse x:Name="SelectedRing"
                                     Stroke="White"
                                     StrokeThickness="2"
                                     Margin="-2"
                                     Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="SelectedRing" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsNone}" Value="True">
                                <Setter TargetName="ColorSwatch" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="NoneImage" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SizeSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource SliderThumbBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SizeSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False" Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource SliderProgressBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SizeSliderThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False" Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource SliderTrackBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource PopupBackgroundBrush}"
            BorderBrush="{StaticResource PopupBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <StackPanel>
            <TextBlock Text="Colours"
                       Foreground="{StaticResource HeaderForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,10" />

            <ItemsControl ItemsSource="{Binding Colors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ColorSwatchStyle}"
                                Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Opacity"
                       Foreground="{StaticResource HeaderForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,16,0,8" />

            <Slider Style="{StaticResource SizeSliderStyle}"
                    Minimum="0"
                    Maximum="1"
                    Value="{Binding Opacity}"
                    IsMoveToPointEnabled="True" />

            <TextBlock Text="Size"
                       Foreground="{StaticResource HeaderForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,16,0,8" />

            <Grid Height="60">
                <Path Stroke="White"
                      StrokeThickness="{Binding Size}"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M 10,40 C 60,5 120,55 180,20 C 220,-5 260,45 290,25"
                      Stretch="None"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Grid>

            <Slider Style="{StaticResource SizeSliderStyle}"
                    Minimum="{Binding MinSize}"
                    Maximum="{Binding MaxSize}"
                    Value="{Binding Size}"
                    IsMoveToPointEnabled="True"
                    Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
