<UserControl x:Class="Flicksy.PostSnip.Controls.ShapeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Flicksy.PostSnip.Controls"
             HorizontalAlignment="Left">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ShapeButtonHoverBrush" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="ShapeButtonPressedBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="ShapeButtonSelectedBrush" Color="#0078D4" />

        <SolidColorBrush x:Key="PillButtonBackgroundBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="PillButtonBorderBrush" Color="#3DFFFFFF" />
        <SolidColorBrush x:Key="PillButtonHoverBrush" Color="#353535" />
        <SolidColorBrush x:Key="PillButtonPressedBrush" Color="#202020" />

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PillButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PillButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="{StaticResource PillButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="{StaticResource PillButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PillBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShapeIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ShapeButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ShapeButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ShapeButtonSelectedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource PopupBackgroundBrush}"
            BorderBrush="{StaticResource PopupBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <StackPanel>
            <TextBlock Text="Shapes"
                       Foreground="{StaticResource HeaderForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,10" />

            <ItemsControl ItemsSource="{Binding Shapes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ShapeIconButtonStyle}"
                                ToolTip="{Binding Name}"
                                Command="{Binding DataContext.SelectShapeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Image Source="{Binding Icon}" Width="28" Height="28" Stretch="Uniform" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0">
                <Button x:Name="FillPillButton"
                        Style="{StaticResource PillButtonStyle}"
                        Margin="0,0,6,0"
                        IsEnabled="{Binding IsFillEnabled}"
                        Command="{Binding ToggleFillSettingsCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="18" Height="18" VerticalAlignment="Center">
                            <Image Source="{Binding CircleOutside}" Stretch="Uniform" />
                            <Rectangle Fill="{Binding FillSettings.SelectedColor.Brush}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding CircleInside}" Stretch="Uniform" />
                                </Rectangle.OpacityMask>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FillSettings.SelectedColor.IsNone}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                        <TextBlock Text="Fill"
                                   VerticalAlignment="Center"
                                   Margin="6,0,4,0" />
                        <Path Data="M 0,0 L 4,4 L 8,0"
                              Stroke="White"
                              StrokeThickness="1.5"
                              VerticalAlignment="Center"
                              Margin="2,2,0,0" />
                    </StackPanel>
                </Button>
                <Popup x:Name="FillSettingsPopup"
                       PlacementTarget="{Binding ElementName=FillPillButton}"
                       Placement="Bottom"
                       VerticalOffset="6"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       IsOpen="{Binding IsFillSettingsOpen, Mode=TwoWay}"
                       Opened="OnFillSettingsPopupOpened">
                    <controls:FillSettingsView DataContext="{Binding FillSettings}" />
                </Popup>
                <Button x:Name="OutlinePillButton"
                        Style="{StaticResource PillButtonStyle}"
                        Command="{Binding ToggleOutlineSettingsCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="18" Height="18" VerticalAlignment="Center">
                            <Image Source="{Binding DonutOutside}" Stretch="Uniform" />
                            <Rectangle Fill="{Binding OutlineSettings.SelectedColor.Brush}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding DonutInside}" Stretch="Uniform" />
                                </Rectangle.OpacityMask>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutlineSettings.SelectedColor.IsNone}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                        <TextBlock Text="Outline"
                                   VerticalAlignment="Center"
                                   Margin="6,0,4,0" />
                        <Path Data="M 0,0 L 4,4 L 8,0"
                              Stroke="White"
                              StrokeThickness="1.5"
                              VerticalAlignment="Center"
                              Margin="2,2,0,0" />
                    </StackPanel>
                </Button>
                <Popup x:Name="OutlineSettingsPopup"
                       PlacementTarget="{Binding ElementName=OutlinePillButton}"
                       Placement="Bottom"
                       VerticalOffset="6"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       IsOpen="{Binding IsOutlineSettingsOpen, Mode=TwoWay}"
                       Opened="OnOutlineSettingsPopupOpened">
                    <controls:OutlineSettingsView DataContext="{Binding OutlineSettings}" />
                </Popup>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
