<Window x:Class="Flicksy.Snipper.Overlays.PreSnipOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        Focusable="True"
        KeyDown="OnWindowKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseLeftButtonUp">
    <Window.Resources>
        <SolidColorBrush x:Key="OverlayMenuBackgroundBrush" Color="#CC1F1F1F" />
        <SolidColorBrush x:Key="OverlayMenuBorderBrush" Color="#66FFFFFF" />
        <SolidColorBrush x:Key="OverlayTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ModeButtonBackgroundBrush" Color="#333333" />
        <SolidColorBrush x:Key="ModeButtonHoverBrush" Color="#3F3F3F" />
        <SolidColorBrush x:Key="ModeButtonBorderBrush" Color="#55FFFFFF" />

        <Style x:Key="ModeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ModeButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ModeButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ModeButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image x:Name="BackgroundImage" Stretch="Fill" />

        <Canvas x:Name="OverlayCanvas" Background="Transparent">
            <Rectangle x:Name="TopShade" Fill="#70000000" />
            <Rectangle x:Name="LeftShade" Fill="#70000000" />
            <Rectangle x:Name="RightShade" Fill="#70000000" />
            <Rectangle x:Name="BottomShade" Fill="#70000000" />
            <Rectangle x:Name="SelectionBorder"
                       Fill="Transparent"
                       Stroke="White"
                       StrokeThickness="2"
                       Visibility="Collapsed" />
        </Canvas>

        <Border x:Name="MenuBorder"
                Panel.ZIndex="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Padding="12,10,16,10"
                Background="{StaticResource OverlayMenuBackgroundBrush}"
                BorderBrush="{StaticResource OverlayMenuBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Cursor="Arrow">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="SnipModeButton"
                        Grid.Column="0"
                        Style="{StaticResource ModeButtonStyle}"
                        Width="34"
                        Height="34"
                        Margin="0,0,6,0"
                        ToolTip="Snip mode"
                        Click="OnSnipModeClick">
                    <Image Width="20"
                           Height="20"
                           Stretch="Uniform"
                           Source="pack://application:,,,/Resources/camera-icon.png" />
                </Button>
                <Button x:Name="RecordModeButton"
                        Grid.Column="1"
                        Style="{StaticResource ModeButtonStyle}"
                        Width="34"
                        Height="34"
                        ToolTip="Record mode"
                        Click="OnRecordModeClick">
                    <Image Width="20"
                           Height="20"
                           Stretch="Uniform"
                           Source="pack://application:,,,/Resources/camcorder-icon.png" />
                </Button>
                <TextBlock x:Name="InstructionText"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource OverlayTextBrush}"
                           FontSize="14"
                           Text="Click and drag an area to snip" />
            </Grid>
        </Border>
    </Grid>
</Window>
